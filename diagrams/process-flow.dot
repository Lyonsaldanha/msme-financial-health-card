digraph process_flow {
  layout=neato;
  bgcolor="white";
  fontname="Helvetica";
  graph [splines=line];
  node [fontname="Helvetica", style="rounded,filled"];
  edge [fontname="Helvetica", fontsize=10, color="#666666", arrowsize=0.8, penwidth=1.3];

  start [label="Lender logs in
(Streamlit)", shape=ellipse, fillcolor="#FFCDD2", fontsize=13, style="filled", pos="0,350!"];
  select [label="Select customer
from dashboard", shape=box, fillcolor="#FFE0B2", fontsize=13, style="rounded,filled", pos="235,350!"];
  generate [label="Click
\"Generate Health Card\"", shape=box, fillcolor="#FFE0B2", fontsize=13, style="rounded,filled", pos="470,350!"];
  ratios [label="Compute GST / UPI /
AA / EPFO ratios", shape=box, fillcolor="#C8E6C9", fontsize=13, style="rounded,filled", pos="705,350!"];
  ntc [label="GST-registered?
Yes: score normally
No (NTC): neutral 50, NA", shape=diamond, fillcolor="#FFF3C4", fontsize=12, style="filled", pos="940,350!", margin="0.2,0.12"];
  crossval [label="Cross-validate sources
(GST vs AA vs UPI vs EPFO)", shape=box, fillcolor="#C8E6C9", fontsize=13, style="rounded,filled", pos="0,175!"];
  composite [label="Weighted composite score
(0-100) + red/green flags", shape=box, fillcolor="#C8E6C9", fontsize=13, style="rounded,filled", pos="235,175!"];
  save_sc [label="Persist
scorecard", shape=cylinder, fillcolor="#E1BEE7", fontsize=12, style="filled", pos="470,175!"];
  facts [label="Retrieve
scorecard facts", shape=box, fillcolor="#FFF9C4", fontsize=13, style="rounded,filled", pos="705,175!"];
  gemini [label="Gemini available
& in quota?
Yes: LLM narrative
No: deterministic fallback", shape=diamond, fillcolor="#FFF3C4", fontsize=12, style="filled", pos="940,175!", margin="0.22,0.14"];
  chart [label="Build chart configs
(code, not LLM)", shape=box, fillcolor="#FFF9C4", fontsize=13, style="rounded,filled", pos="0,0!"];
  save_rep [label="Persist
report", shape=cylinder, fillcolor="#E1BEE7", fontsize=12, style="filled", pos="235,0!"];
  render [label="Render Health Card:
gauge, scores, charts,
flags, narrative", shape=box, fillcolor="#BBDEFB", fontsize=13, style="rounded,filled", pos="470,0!"];
  decision [label="Lender views score,
downloads JSON,
decides", shape=ellipse, fillcolor="#FFCDD2", fontsize=13, style="filled", pos="705,0!"];

  start -> select;
  select -> generate;
  generate -> ratios;
  ratios -> ntc;
  ntc -> crossval [penwidth=1.6, color="#333333"];
  crossval -> composite;
  composite -> save_sc;
  save_sc -> facts;
  facts -> gemini;
  gemini -> chart [penwidth=1.6, color="#333333"];
  chart -> save_rep;
  save_rep -> render;
  render -> decision;
}
